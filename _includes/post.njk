<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} | 사주천명연구소</title>
  <meta name="description" content="{{ description or title }}">
  <link rel="canonical" href="https://sajucmlab.com{{ page.url }}">
</head>
<body>
  <header>
    <a href="/">사주천명연구소</a>
  </header>

  <main>
    <article>
      <h1>{{ title }}</h1>
      {% if date %}
      <p>{{ date }}</p>
      {% endif %}
      {{ content | safe }}
    </article>
  </main>

  <footer>
    <p>© 사주천명연구소</p>
  </footer>
</body>
</html>
